# ============================================
# 🔧 CONFIGURACIÓN DE ENTORNO (ejemplo)
# ============================================

# --- Flask ---
SECRET_KEY=cambia-esto-por-un-token-seguro
FLASK_DEBUG=0
PORT=80

# --- Base de Datos PostgreSQL (producción/deploy) ---
DB_USER=usuario
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nombre_bd

# --- Correo (Flask-Mail) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_DEFAULT_SENDER=noreply@brazo.com

# --- Administrador por defecto (Desarrollo/Seed) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@brazo.com
ADMIN_PASSWORD=cambia-esto-por-un-password-seguro

# --- Seguridad ---
PASSWORD_RESET_SALT=cambia-esto-por-un-salt-aleatorio
